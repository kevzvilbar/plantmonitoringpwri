# =============================================================================
# PWRI Plant Monitoring — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# In Vercel: these are automatically set by the Supabase integration.
# =============================================================================

# ---- Supabase (Auto-configured by Vercel Integration) ----------------------
# These are automatically set when you connect Supabase via Vercel:
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY

# For Vite frontend (prefix with VITE_):
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# ---- MongoDB (Optional - for AI chat history) ------------------------------
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB_NAME=pwri

# ---- OpenAI (Optional - for AI features) -----------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ---- Security --------------------------------------------------------------
# Random 32+ char string for cron job authentication
CRON_SECRET=your_random_cron_secret_here
