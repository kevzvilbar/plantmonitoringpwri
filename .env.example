# =============================================================================
# PWRI Plant Monitoring — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# In Vercel: set these in Project Settings → Environment Variables.
# =============================================================================

# ---- Supabase (Frontend + Backend) ----------------------------------------
# Get these from: https://app.supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Backend-only (Vercel Functions) — add without VITE_ prefix
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- MongoDB (for AI chat history, compliance, blending, downtime) ---------
# Recommended: MongoDB Atlas free tier — https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=pwri

# ---- OpenAI (AI Assistant, Anomaly Detection, Compliance Summaries) --------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---- Security --------------------------------------------------------------
# Random 32+ char string for cron job authentication
CRON_SECRET=your_random_cron_secret_here

# CORS — in production, set to your Vercel deployment URL
CORS_ORIGIN=*

# ---- Optional: API URL override for local dev ------------------------------
# Only needed when running frontend separately from Vercel dev server
# VITE_API_URL=http://localhost:8000
